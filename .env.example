# Avon Industrial Agent — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────
PORT=4000

# ── JWT Auth ─────────────────────────────────────────────────
# CHANGE THIS to a cryptographically random string in production.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# ── Supabase ─────────────────────────────────────────────────
# Your project URL (safe to include in client AND server)
SUPABASE_URL=https://your-project.supabase.co

# Server-side only (Admin/Service Role key — NEVER expose to client)
# Found in: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Public/Anon key (safe for client-side use only)
# Found in: Supabase Dashboard → Settings → API → anon key
SUPABASE_ANON_KEY=eyJ...

# ── AI Providers ─────────────────────────────────────────────
# Leave blank to use local Ollama. Set to enable OpenAI cloud mode.
OPENAI_API_KEY=

# ── Evolution Engine ─────────────────────────────────────────
# Set to 'auto' to start the evolution monitor automatically on server boot.
# Set to 'manual' (or leave blank) to keep the engine in STANDBY.
EVOLUTION_MODE=manual

# ── Optional: Stripe (if payment features are enabled) ────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
