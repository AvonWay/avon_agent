#parse("src/macros/ui.vm")

#set( $pageTitle = "Avon Agent Chat — Velocity" )
#set( $pageDescription = "Interact with Avon, your autonomous agent." )

<section class="py-8 md:py-12">
    <div class="flex flex-col gap-2 mb-8">
        <h1 class="text-3xl font-bold tracking-tight">Chat with Avon</h1>
        <p class="text-muted-foreground">Coordinate with your autonomous agent for project execution.</p>
    </div>

    <div class="grid gap-6 lg:grid-cols-12 h-[600px]">
        <!-- Chat Interface -->
        <div class="lg:col-span-8 flex flex-col rounded-lg border bg-card shadow-sm overflow-hidden">
            <div class="p-4 border-b bg-muted/30 flex justify-between items-center">
                <div class="flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                    <span class="text-sm font-semibold">Avon:latest</span>
                </div>
                #badge("Industrial Mode", "secondary")
            </div>
            
            <div id="chat-messages" class="flex-1 overflow-y-auto p-6 space-y-4 bg-background">
                <div class="flex gap-3 max-w-[80%] opacity-80">
                    <div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center text-xs font-bold text-primary shrink-0">AV</div>
                    <div class="space-y-1">
                        <p class="text-xs font-semibold text-muted-foreground">Avon Agent</p>
                        <div class="p-3 rounded-lg bg-muted text-sm shadow-sm">
                            Greetings. I am ready to assist with your industrial build tasks. What are we building today?
                        </div>
                    </div>
                </div>
            </div>

            <div class="p-4 border-t bg-muted/10">
                <div class="relative">
                    <textarea 
                        id="chat-input"
                        placeholder="Describe your project or task..."
                        class="w-full p-4 pr-24 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 resize-none h-24"
                    ></textarea>
                    <div class="absolute right-3 bottom-3 flex gap-2">
                        <button 
                            id="attach-btn"
                            class="p-2 rounded-md bg-muted text-muted-foreground hover:bg-muted/80 transition-colors"
                            aria-label="Attach files"
                            title="Attach files"
                        >
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="12" y1="5" x2="12" y2="19"></line>
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                            </svg>
                        </button>
                        <input type="file" id="file-input" multiple class="hidden">
                        <button 
                            id="voice-btn"
                            class="p-2 rounded-md bg-muted text-muted-foreground hover:bg-muted/80 transition-colors"
                            aria-label="Voice control"
                            title="Voice control"
                        >
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"></path>
                                <path d="M19 10v2a7 7 0 01-14 0v-2"></path>
                                <line x1="12" y1="19" x2="12" y2="23"></line>
                                <line x1="8" y1="23" x2="16" y2="23"></line>
                            </svg>
                        </button>
                        <button 
                            id="send-btn"
                            class="p-2 rounded-md bg-primary text-primary-foreground hover:bg-primary/90 transition-colors"
                            aria-label="Send message"
                            title="Send message"
                        >
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="22" y1="2" x2="11" y2="13" />
                                <polygon points="22 2 15 22 11 13 2 9 22 2" />
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- System Intelligence (Status & Plan) -->
        <div class="lg:col-span-4 flex flex-col gap-4">
            <div class="rounded-lg border bg-card shadow-sm overflow-hidden p-6">
                <h3 class="font-bold flex items-center gap-2 mb-4">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
                    Intelligence Feed
                </h3>
                <div id="status-feed" class="space-y-4">
                    <div class="flex items-start gap-3">
                        <div class="w-1.5 h-1.5 rounded-full bg-blue-500 mt-1.5"></div>
                        <div class="text-xs">
                            <p class="font-semibold">System Idle</p>
                            <p class="text-muted-foreground">Waiting for task initialization...</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="rounded-lg border bg-card shadow-sm overflow-hidden p-6 flex-1">
                <div class="flex justify-between items-center mb-4">
                    <h3 class="font-bold">Active Plan</h3>
                    #badge("Proposed", "outline")
                </div>
                <div id="active-plan" class="space-y-3">
                    <div class="p-3 rounded border border-dashed text-xs text-muted-foreground flex flex-col items-center justify-center h-40">
                        <p>No active plan to display.</p>
                        <p>Describe a task to generate a blueprint.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
#[[
document.addEventListener('DOMContentLoaded', () => {
    const chatInput = document.getElementById('chat-input');
    const sendBtn = document.getElementById('send-btn');
    const messages = document.getElementById('chat-messages');
    const statusFeed = document.getElementById('status-feed');
    const activePlan = document.getElementById('active-plan');
    let attachedFiles = [];

    const addMessage = (role, text) => {
        const div = document.createElement('div');
        div.className = `flex gap-3 ${role === 'user' ? 'justify-end' : ''}`;
        
        const avatar = role === 'user' ? 'U' : 'AV';
        const color = role === 'user' ? 'bg-blue-600' : 'bg-primary/20';
        const textColor = role === 'user' ? 'text-white' : 'text-primary';
        
        div.innerHTML = `
            ${role === 'ai' ? `<div class="w-8 h-8 rounded-full ${color} flex items-center justify-center text-xs font-bold ${textColor} shrink-0">${avatar}</div>` : ''}
            <div class="space-y-1 ${role === 'user' ? 'items-end' : ''}">
                <p class="text-xs font-semibold text-muted-foreground">${role === 'user' ? 'You' : 'Avon Agent'}</p>
                <div class="p-3 rounded-lg ${role === 'user' ? 'bg-primary text-primary-foreground' : 'bg-muted'} text-sm shadow-sm">
                    ${text}
                </div>
            </div>
            ${role === 'user' ? `<div class="w-8 h-8 rounded-full ${color} flex items-center justify-center text-xs font-bold ${textColor} shrink-0">${avatar}</div>` : ''}
        `;
        messages.appendChild(div);
        messages.scrollTop = messages.scrollHeight;
    };

    // Attachment logic
    const attachBtn = document.getElementById('attach-btn');
    const fileInput = document.getElementById('file-input');

    function toBase64(file) {
        return new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = () => resolve(reader.result);
            reader.onerror = error => reject(error);
        });
    }

    if (attachBtn && fileInput) {
        attachBtn.addEventListener('click', () => fileInput.click());
        fileInput.addEventListener('change', async (e) => {
            if (e.target.files.length > 0) {
                const filenames = Array.from(e.target.files).map(f => f.name).join(', ');
                addMessage('user', `📎 Preparing: ${filenames}`);
                
                for (const file of e.target.files) {
                    if (file.type.startsWith('image/')) {
                        const base64 = await toBase64(file);
                        attachedFiles.push({ type: 'image', name: file.name, data: base64.split(',')[1] });
                    } else {
                        const text = await file.text();
                        attachedFiles.push({ type: 'text', name: file.name, data: text });
                    }
                }

                setTimeout(() => {
                    addMessage('ai', `I've received your ${e.target.files.length} file(s). Analyzing contents with industrial focus... 🚀`);
                }, 1000);
            }
        });
    }

    // Voice logic
    const voiceBtn = document.getElementById('voice-btn');
    let isRecording = false;
    let recognition = null;

    if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        recognition = new SpeechRecognition();
        recognition.continuous = true;
        recognition.interimResults = true;
        recognition.lang = 'en-US';

        recognition.onstart = () => {
            isRecording = true;
            voiceBtn.classList.add('bg-red-100', 'text-red-600', 'animate-pulse');
            chatInput.placeholder = "Listening to your instructions...";
        };

        recognition.onend = () => {
            if (isRecording) {
                try { recognition.start(); } catch(e) {}
            } else {
                voiceBtn.classList.remove('bg-red-100', 'text-red-600', 'animate-pulse');
                chatInput.placeholder = "Describe your project or task...";
            }
        };

        recognition.onresult = (event) => {
            let finalTranscript = '';
            for (let i = event.resultIndex; i < event.results.length; ++i) {
                if (event.results[i].isFinal) {
                    finalTranscript += event.results[i][0].transcript;
                }
            }
            if (finalTranscript) {
                chatInput.value = finalTranscript;
                setTimeout(() => {
                    if (chatInput.value === finalTranscript) {
                        sendBtn.click();
                    }
                }, 1500);
            }
        };
    }

    if (voiceBtn) {
        voiceBtn.addEventListener('click', () => {
            if (!recognition) return;
            if (isRecording) {
                recognition.stop();
            } else {
                recognition.start();
            }
        });
    }

    const updateStatus = (title, desc, color = 'blue') => {
        const div = document.createElement('div');
        div.className = 'flex items-start gap-3 animate-in fade-in slide-in-from-left-2';
        div.innerHTML = `
            <div class="w-1.5 h-1.5 rounded-full bg-${color}-500 mt-1.5"></div>
            <div class="text-xs">
                <p class="font-semibold">${title}</p>
                <p class="text-muted-foreground">${desc}</p>
            </div>
        `;
        statusFeed.prepend(div);
    };

    const updatePlan = (planItems) => {
        activePlan.innerHTML = planItems.map(item => `
            <div class="flex items-center gap-3 p-2 rounded hover:bg-muted/50 transition-colors group">
                <div class="w-4 h-4 rounded border border-primary/30 flex items-center justify-center text-[10px] text-primary group-hover:border-primary/60">
                    ${item.done ? '✓' : ''}
                </div>
                <span class="text-xs ${item.done ? 'line-through opacity-50' : ''}">${item.text}</span>
            </div>
        `).join('');
    };

    const runTask = async (prompt, images = []) => {
        updateStatus('Thinking', 'Avon is analyzing the industrial requirements...', 'yellow');
        
        // Mocking the "abstracted" experience
        setTimeout(() => {
            updatePlan([
                { text: 'Analyze project scope', done: true },
                { text: 'Synthesize industrial logic', done: false },
                { text: 'Deploy to containment', done: false }
            ]);
            updateStatus('Planning', 'Generating architectural blueprint...', 'purple');
            
            setTimeout(() => {
                updateStatus('Executing', 'Building components in background...', 'green');
                updatePlan([
                    { text: 'Analyze project scope', done: true },
                    { text: 'Synthesize industrial logic', done: true },
                    { text: 'Deploy to containment', done: false }
                ]);
                
                setTimeout(() => {
                    addMessage('ai', "Task complete. I have synthesized the requested node and initialized the containment field. You can review the output in the Development IDE.");
                    updateStatus('Complete', 'All industrial processes finalized.', 'green');
                     updatePlan([
                        { text: 'Analyze project scope', done: true },
                        { text: 'Synthesize industrial logic', done: true },
                        { text: 'Deploy to containment', done: true }
                    ]);
                }, 2000);
            }, 1500);
        }, 1000);
    };

    sendBtn.addEventListener('click', () => {
        const text = chatInput.value.trim();
        if(!text && attachedFiles.length === 0) return;
        
        const images = attachedFiles.filter(f => f.type === 'image').map(f => f.data);
        const contexts = attachedFiles.filter(f => f.type === 'text').map(f => `[File: ${f.name}]\n${f.data}`).join('\n\n');
        
        let apiPrompt = text;
        if (contexts) {
            apiPrompt = `Context from uploaded files:\n${contexts}\n\nUser request: ${text}`;
        }

        addMessage('user', text || "Analyzing uploaded assets...");
        chatInput.value = '';
        attachedFiles = [];
        runTask(apiPrompt, images);
    });

    chatInput.addEventListener('keydown', (e) => {
        if(e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendBtn.click();
        }
    });
});
]]#
</script>
